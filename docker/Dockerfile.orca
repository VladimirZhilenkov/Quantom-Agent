# ORCA requires a license — download from https://orcaforum.kofo.mpg.de
FROM ubuntu:22.04

RUN apt-get update && apt-get install -y --no-install-recommends \
    libopenmpi-dev openmpi-bin && \
    rm -rf /var/lib/apt/lists/*

# ORCA binary must be mounted or copied manually
ENV ORCA_BINARY=/opt/orca/orca
ENV PATH="/opt/orca:${PATH}"

WORKDIR /jobs
CMD ["sleep", "infinity"]
